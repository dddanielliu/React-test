// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
  "name": "React Frontend Dev Container",
  "dockerComposeFile": [
    "../../docker-compose.yml",
    "./docker-compose.dev.yml"
  ],
  // "build": {
  //   "dockerfile": "${localWorkspaceFolder}/frontend/Dockerfile",
  //   "context": "../../backend",
  //   "target": "dev"
  // },
  "service": "frontend",
  // "workspaceMount": "source=${localWorkspaceFolder},target=/NoSquad,type=bind",
  "workspaceFolder": "/React-test/frontend",
  // This tells Docker to load the .env file when starting the container
  "overrideCommand": true,
  // Variables used in all of the container. Rebuild is required if you want to modify
  "containerEnv": {
    "GIT_EDITOR": "vim"
  },
  // Variables used for the devcontainer.json supporting service / tool
  //   "remoteEnv": {
  //     "GIT_AUTH_TOKEN": "${localEnv:GIT_AUTH_TOKEN}"
  //   },
  // "onCreateCommand": "",
  "postCreateCommand": ["npm", "install"],
  // "postStartCommand": "",
  // "postAttachCommand": {}
  // "runArgs": ["--env-file","${localWorkspaceFolder}/.env"],

  "customizations": {
    "vscode": {
      "extensions": [
        "oxc.oxc-vscode",
        "dsznajder.es7-react-js-snippets"
      ],
      "settings": {
        "git.openRepositoryInParentFolders": "always"
      }
    }
  }
}
